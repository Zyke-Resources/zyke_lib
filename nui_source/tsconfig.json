{
	"compilerOptions": {
		"target": "ES2021",
		"lib": [
			"ES2021",
			"DOM",
			"DOM.Iterable"
		],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"noEmit": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"allowJs": true,
		"checkJs": false,
		"types": [
			"vite/client"
		]
	},
	"include": [
		"src"
	]
}